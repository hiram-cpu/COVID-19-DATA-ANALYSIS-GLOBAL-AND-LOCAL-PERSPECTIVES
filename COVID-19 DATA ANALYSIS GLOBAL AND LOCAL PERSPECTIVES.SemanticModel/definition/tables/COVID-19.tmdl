table COVID-19
	lineageTag: f3be9407-61fc-4752-ae86-200caca217c0

	measure 'Total Confirmed' = ```
			
			VAR CONFIRMED = 
			SUMX(
			    VALUES('COVID-19'[Country/Region]),
			    SUMX(
			        VALUES('COVID-19'[Province/State]),
			        CALCULATE(
			            MAX('COVID-19'[Confirmed])
			        )
			    )
			)
			RETURN
			IF(CONFIRMED = 0, BLANK(), CONFIRMED)
			```
		lineageTag: 2a3579df-3e7b-49f1-bb54-5b6024da5485

	measure 'Total Deaths' = ```
			
			VAR DEATHS = 
			SUMX(
			    VALUES('COVID-19'[Country/Region]),
			    SUMX(
			        VALUES('COVID-19'[Province/State]),
			        CALCULATE(
			            MAX('COVID-19'[Deaths])
			        )
			    )
			)
			RETURN
			IF(DEATHS = 0, BLANK(), DEATHS)
			```
		lineageTag: f552accf-d0ff-4f46-b13d-f68d1570106e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Daily New Cases' = ```
			
			VAR CURRENT_DAY = 
			    [Total Confirmed]
			VAR PREVIOS_DAY = 
			    CALCULATE([Total Confirmed], 
			        DATEADD('CALENDAR'[Date], -1, DAY)
			    )
			RETURN 
			IF(ISBLANK(PREVIOS_DAY), BLANK(), CURRENT_DAY - PREVIOS_DAY)
			```
		lineageTag: dd39012f-090c-435d-9855-d23d03917f34

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tasa de Mortalidad' = ```
			
			DIVIDE(
			    'COVID-19'[Total Deaths], 
			    'COVID-19'[Total Confirmed], 
			    0
			)
			```
		lineageTag: 19bd75eb-87b2-4edc-ae81-fd8baf5711a5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

